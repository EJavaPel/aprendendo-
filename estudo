<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>C++ Master - 30 Desafios</title>
    <style>
        :root {
            --cpp-blue: #004482;
            --cpp-light: #659ad2;
            --bg: #0f0f0f;
            --surface: #1a1a1a;
            --text: #e0e0e0;
            --primary: #00ff95;
        }

        body {
            font-family: 'Segoe UI', Tahoma, sans-serif;
            background: var(--bg);
            color: var(--text);
            margin: 0;
            display: flex;
            flex-direction: column;
            height: 100vh;
        }

        header {
            background: var(--surface);
            padding: 15px 25px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 2px solid var(--cpp-blue);
        }

        .logo { font-weight: bold; color: var(--cpp-light); font-size: 1.2rem; }

        main {
            display: grid;
            grid-template-columns: 300px 1fr;
            flex: 1;
            overflow: hidden;
        }

        #sidebar {
            background: #111;
            border-right: 1px solid #333;
            overflow-y: auto;
            padding: 15px;
        }

        .q-item {
            padding: 12px;
            margin-bottom: 8px;
            background: #1e1e1e;
            border-radius: 5px;
            cursor: pointer;
            font-size: 14px;
            transition: 0.2s;
            border-left: 4px solid transparent;
        }

        .q-item:hover { background: #252525; }
        .q-active { border-left-color: var(--primary); background: #252525; }

        #content {
            display: grid;
            grid-template-rows: auto 1fr 180px;
            padding: 0;
        }

        #info {
            padding: 20px 40px;
            background: #161616;
            border-bottom: 1px solid #333;
        }

        #editor-container {
            position: relative;
            background: #1e1e1e;
        }

        .toolbar {
            background: #252525;
            padding: 8px 20px;
            display: flex;
            justify-content: space-between;
            font-size: 12px;
            color: #888;
        }

        textarea {
            width: 100%;
            height: calc(100% - 35px);
            background: #1e1e1e;
            color: #dcdcdc;
            padding: 20px;
            border: none;
            font-family: 'Consolas', 'Courier New', monospace;
            font-size: 16px;
            outline: none;
            resize: none;
            box-sizing: border-box;
        }

        #console {
            background: #000;
            color: #00ff00;
            padding: 15px 25px;
            font-family: 'Consolas', monospace;
            overflow-y: auto;
            border-top: 2px solid #333;
        }

        .btn-run {
            background: var(--cpp-blue);
            color: white;
            border: none;
            padding: 8px 25px;
            border-radius: 4px;
            font-weight: bold;
            cursor: pointer;
        }

        .btn-run:hover { background: var(--cpp-light); }

        .hint { color: #aaa; font-size: 13px; margin-top: 10px; font-style: italic; display: none; }
    </style>
</head>
<body>

<header>
    <div class="logo">C++ ACADEMY //</div>
    <div id="progresso">Nível 1 de 30</div>
</header>

<main>
    <nav id="sidebar"></nav>

    <section id="content">
        <div id="info">
            <h2 id="q-title" style="margin:0; color: var(--primary);">Olá C++</h2>
            <p id="q-desc" style="margin:10px 0; color: #ccc;"></p>
            <button onclick="document.getElementById('hint').style.display='block'" style="background:none; border:1px solid #444; color:#888; cursor:pointer; font-size:11px;">DICA</button>
            <div id="hint" class="hint"></div>
        </div>

        <div id="editor-container">
            <div class="toolbar">
                <span>main.cpp</span>
                <button class="btn-run" onclick="rodar()">COMPILAR E RODAR</button>
            </div>
            <textarea id="editor" spellcheck="false"></textarea>
        </div>

        <div id="console"></div>
    </section>
</main>

<script>
    const exercicios = [
        {
            id: 1,
            titulo: "Saída de Dados",
            desc: "Use 'std::cout' para imprimir 'Ola Mundo' na tela.",
            hint: "Lembre-se do #include <iostream> e do cout << 'texto';",
            padrao: "#include <iostream>\n\nint main() {\n    std::cout << \"Ola Mundo\";\n    return 0;\n}"
        },
        {
            id: 2,
            titulo: "Entrada de Dados",
            desc: "Crie uma variável inteira, use 'std::cin' para ler um valor e depois imprima-o.",
            hint: "int x; std::cin >> x;",
            padrao: "#include <iostream>\n\nint main() {\n    int idade;\n    std::cout << \"Digite sua idade: \";\n    // seu codigo aqui\n    return 0;\n}"
        },
        {
            id: 10,
            titulo: "Condicional If/Else",
            desc: "Leia um número e diga se ele é positivo ou negativo.",
            hint: "if (num >= 0) { ... }",
            padrao: "#include <iostream>\n\nint main() {\n    int n;\n    std::cin >> n;\n    return 0;\n}"
        },
        {
            id: 30,
            titulo: "Calculadora C++",
            desc: "Crie uma calculadora que use switch/case para as 4 operações matemáticas.",
            hint: "switch(operador) { case '+': ... }",
            padrao: "#include <iostream>\n\nint main() {\n    char op;\n    float n1, n2;\n    // O desafio final!\n    return 0;\n}"
        }
    ];

    // Gerador de questões restantes
    for(let i=1; i<=30; i++) {
        if(!exercicios.find(x => x.id === i)) {
            exercicios.push({
                id: i,
                titulo: `Logica C++ Nível ${i}`,
                desc: `Pratique a sintaxe de C++. Resolva o desafio proposto para o nível ${i}.`,
                hint: "Use cin para entrada e cout para saída.",
                padrao: "#include <iostream>\nusing namespace std;\n\nint main() {\n    // Pratique aqui\n    return 0;\n}"
            });
        }
    }
    exercicios.sort((a,b) => a.id - b.id);

    const sidebar = document.getElementById('sidebar');
    const editor = document.getElementById('editor');
    const consoleDiv = document.getElementById('console');
    let atual = 1;

    exercicios.forEach(ex => {
        const item = document.createElement('div');
        item.className = 'q-item';
        item.id = `nav-${ex.id}`;
        item.innerHTML = `<strong>${ex.id}.</strong> ${ex.titulo}`;
        item.onclick = () => carregar(ex.id);
        sidebar.appendChild(item);
    });

    function carregar(id) {
        atual = id;
        const ex = exercicios.find(x => x.id === id);
        document.getElementById('q-title').innerText = ex.titulo;
        document.getElementById('q-desc').innerText = ex.desc;
        document.getElementById('hint').innerText = ex.hint;
        document.getElementById('hint').style.display = 'none';
        document.getElementById('progresso').innerText = `Nível ${id} de 30`;
        
        const salvo = localStorage.getItem(`cpp_save_${id}`);
        editor.value = salvo || ex.padrao;

        document.querySelectorAll('.q-item').forEach(e => e.classList.remove('q-active'));
        document.getElementById(`nav-${id}`).classList.add('q-active');
    }

    function rodar() {
        consoleDiv.innerHTML = "Compilando main.cpp...<br>Executando...<br><br>";
        const codigo = editor.value;
        localStorage.setItem(`cpp_save_${atual}`, codigo);

        // Simulador de C++ para Browser
        const print = (t) => { consoleDiv.innerHTML += t + "<br>"; };
        const scan = (m) => prompt(m);

        // Tradutor simples para simular C++ usando JS
        let jsCode = codigo
            .replace(/std::cout\s*<<\s*/g, "print(")
            .replace(/cout\s*<<\s*/g, "print(")
            .replace(/<<\s*std::endl/g, ")")
            .replace(/<<\s*endl/g, ")")
            .replace(/;/g, ");")
            .replace(/std::cin\s*>>\s*/g, "var ")
            .replace(/cin\s*>>\s*/g, "var ");

        // Devido à complexidade de rodar C++ real no navegador sem servidor,
        // este simulador valida se a sintaxe básica está presente.
        if (codigo.includes("cout") || codigo.includes("cin")) {
            try {
                // Aqui simulamos apenas a saída para fins educacionais
                // Em um ambiente real, precisaríamos de um compilador WebAssembly (como o Emscripten)
                const linhas = codigo.match(/".*?"/g);
                if(linhas) {
                    linhas.forEach(l => print(l.replace(/"/g, "")));
                } else {
                    print("Código C++ aceito. (Simulação de saída)");
                }
            } catch(e) {
                print("Erro de sintaxe próximo ao ponto selecionado.");
            }
        } else {
            print("Erro: main.cpp precisa conter std::cout ou std::cin.");
        }
    }

    carregar(1);
</script>
</body>
</html>
