<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>C++ Academy Pro - 30 Desafios</title>
    <style>
        :root { --primary: #659ad2; --accent: #00ff95; --bg: #0d1117; --surface: #161b22; --border: #30363d; --text: #c9d1d9; }
        body { font-family: 'Segoe UI', sans-serif; background: var(--bg); color: var(--text); margin: 0; display: flex; flex-direction: column; height: 100vh; overflow: hidden; }
        header { background: var(--surface); padding: 10px 20px; border-bottom: 1px solid var(--border); display: flex; justify-content: space-between; align-items: center; }
        .logo { color: var(--primary); font-weight: 800; font-size: 1.2rem; }
        main { display: grid; grid-template-columns: 320px 1fr; flex: 1; overflow: hidden; }
        #sidebar { background: var(--surface); border-right: 1px solid var(--border); overflow-y: auto; padding: 15px; }
        .q-item { padding: 12px; margin-bottom: 8px; border-radius: 6px; cursor: pointer; font-size: 13px; transition: 0.2s; background: #21262d44; border: 1px solid #30363d; }
        .q-item:hover { background: #30363d; border-color: var(--primary); }
        .q-active { background: #23863633; border-color: #238636; color: var(--accent); font-weight: bold; }
        #editor-container { display: grid; grid-template-rows: auto 1fr 180px; overflow: hidden; }
        #instructions { background: #0d1117; padding: 20px; border-bottom: 1px solid var(--border); }
        .toolbar { background: #161b22; padding: 8px 20px; display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid var(--border); }
        textarea { background: #0d1117; color: #79c0ff; padding: 20px; border: none; font-family: 'Consolas', monospace; font-size: 15px; outline: none; resize: none; }
        #console { background: #000; color: #00ff00; padding: 15px; font-family: monospace; font-size: 13px; overflow-y: auto; border-top: 1px solid var(--border); white-space: pre-wrap; }
        .btn-run { background: #238636; color: white; border: none; padding: 10px 25px; border-radius: 6px; font-weight: bold; cursor: pointer; }
        .btn-run:hover { background: #2ea043; }
    </style>
</head>
<body>

<header>
    <div class="logo">C++ ACADEMY // 30 QUESTÕES</div>
    <div id="stat">Questão 1 de 30</div>
</header>

<main>
    <nav id="sidebar"></nav>
    <section id="editor-container">
        <div id="instructions">
            <h2 id="title" style="margin:0; color:var(--primary); font-size: 1.3rem;">Carregando...</h2>
            <p id="desc" style="margin: 8px 0; font-size: 1rem; line-height: 1.4; color: #8b949e;"></p>
            <small id="hint" style="color: #d2a8ff; font-style: italic;"></small>
        </div>

        <div style="display:flex; flex-direction:column; overflow:hidden;">
            <div class="toolbar"><span>main.cpp</span><button class="btn-run" onclick="runCpp()">EXECUTAR CÓDIGO</button></div>
            <textarea id="code-editor" spellcheck="false"></textarea>
        </div>

        <div id="console">O terminal C++ aparecerá aqui após a execução...</div>
    </section>
</main>

<script>
    const questions = [
        // FASE 1: BÁSICO E MATEMÁTICA
        { id: 1, title: "Saída Simples", desc: "Use cout para imprimir a frase 'Aprendendo C++' na tela.", hint: "Dica: std::cout << \"texto\";", code: "#include <iostream>\n\nint main() {\n    // Seu código aqui\n    return 0;\n}" },
        { id: 2, title: "Entrada de Usuário", desc: "Crie uma variável do tipo int, leia um valor com cin e depois imprima 'Valor: ' seguido da variável.", hint: "Dica: cin >> variavel;", code: "#include <iostream>\nusing namespace std;\n\nint main() {\n    int num;\n    return 0;\n}" },
        { id: 3, title: "Soma de Dois Números", desc: "Leia dois números inteiros e imprima a soma deles.", hint: "Dica: cin >> a >> b;", code: "#include <iostream>\nusing namespace std;\n\nint main() {\n    return 0;\n}" },
        { id: 4, title: "Cálculo de Dobro", desc: "Leia um número e mostre o dobro dele (num * 2).", hint: "Dica: cout << n * 2;", code: "#include <iostream>\nusing namespace std;\n\nint main() {\n    return 0;\n}" },
        { id: 5, title: "Média Simples", desc: "Leia duas notas (float) e calcule a média aritmética.", hint: "Dica: (n1 + n2) / 2.0", code: "#include <iostream>\nusing namespace std;\n\nint main() {\n    return 0;\n}" },
        { id: 6, title: "Área do Círculo", desc: "Leia o raio e calcule a área (3.14 * raio * raio).", hint: "Use float para o raio.", code: "#include <iostream>\nusing namespace std;\n\nint main() {\n    return 0;\n}" },
        { id: 7, title: "Conversor de Temperatura", desc: "Converta Celsius para Fahrenheit. Fórmula: (C * 9/5) + 32.", hint: "F = (C * 1.8) + 32", code: "#include <iostream>\nusing namespace std;\n\nint main() {\n    return 0;\n}" },
        { id: 8, title: "Resto da Divisão", desc: "Leia dois números e mostre o resto da divisão entre eles.", hint: "Use o operador %", code: "#include <iostream>\nusing namespace std;\n\nint main() {\n    return 0;\n}" },
        { id: 9, title: "Horas para Minutos", desc: "Leia um valor em horas e transforme em minutos (horas * 60).", hint: "Dica: use int.", code: "#include <iostream>\nusing namespace std;\n\nint main() {\n    return 0;\n}" },
        { id: 10, title: "Sucessor Inteiro", desc: "Leia um número e mostre o sucessor dele (n + 1).", hint: "Ex: Entrou 5, sai 6.", code: "#include <iostream>\nusing namespace std;\n\nint main() {\n    return 0;\n}" },

        // FASE 2: CONDICIONAIS (IF/ELSE)
        { id: 11, title: "Verificar Maioridade", desc: "Leia a idade. Se for >= 18 imprima 'Maior', senão 'Menor'.", hint: "Use if(idade >= 18)", code: "#include <iostream>\nusing namespace std;\n\nint main() {\n    return 0;\n}" },
        { id: 12, title: "Par ou Ímpar", desc: "Leia um número e diga se é Par ou Impar.", hint: "Use if (n % 2 == 0)", code: "#include <iostream>\nusing namespace std;\n\nint main() {\n    return 0;\n}" },
        { id: 13, title: "Positivo ou Negativo", desc: "Diga se o número é Positivo, Negativo ou Zero.", hint: "Use else if", code: "#include <iostream>\nusing namespace std;\n\nint main() {\n    return 0;\n}" },
        { id: 14, title: "Maior de Dois", desc: "Leia A e B e imprima apenas o maior valor.", hint: "if (a > b) { cout << a; }", code: "#include <iostream>\nusing namespace std;\n\nint main() {\n    return 0;\n}" },
        { id: 15, title: "Aprovação Escolar", desc: "Leia a nota. Se nota >= 7 'Aprovado', entre 5 e 6.9 'Recuperação', < 5 'Reprovado'.", hint: "Use múltiplos else if.", code: "#include <iostream>\nusing namespace std;\n\nint main() {\n    return 0;\n}" },
        { id: 16, title: "Login de Senha", desc: "Peça a senha (int). Se for 2024 imprima 'Acesso Liberado', senão 'Negado'.", hint: "if (senha == 2024)", code: "#include <iostream>\nusing namespace std;\n\nint main() {\n    return 0;\n}" },
        { id: 17, title: "Calculadora de Desconto", desc: "Leia o valor da compra. Se for > 100, aplique 10% de desconto.", hint: "preco * 0.9", code: "#include <iostream>\nusing namespace std;\n\nint main() {\n    return 0;\n}" },
        { id: 18, title: "Múltiplo de 5", desc: "Verifique se um número digitado é múltiplo de 5.", hint: "n % 5 == 0", code: "#include <iostream>\nusing namespace std;\n\nint main() {\n    return 0;\n}" },
        { id: 19, title: "Vogal 'A'", desc: "Leia um caractere (char). Se for 'a' imprima 'Vogal', senão 'Outro'.", hint: "if (letra == 'a')", code: "#include <iostream>\nusing namespace std;\n\nint main() {\n    return 0;\n}" },
        { id: 20, title: "Triângulo Válido", desc: "Leia 3 lados. Se a soma de dois for maior que o terceiro, é 'Valido'.", hint: "if(a+b > c && a+c > b ...)", code: "#include <iostream>\nusing namespace std;\n\nint main() {\n    return 0;\n}" },

        // FASE 3: LOOPS E AVANÇADO
        { id: 21, title: "Contagem de 1 a 10", desc: "Use um loop 'for' para imprimir números de 1 a 10.", hint: "for(int i=1; i<=10; i++)", code: "#include <iostream>\nusing namespace std;\n\nint main() {\n    return 0;\n}" },
        { id: 22, title: "Tabuada Fixa", desc: "Use um loop para mostrar a tabuada do 7 (7x1 até 7x10).", hint: "cout << \"7 x \" << i << \" = \" << 7*i;", code: "#include <iostream>\nusing namespace std;\n\nint main() {\n    return 0;\n}" },
        { id: 23, title: "Soma Acumulada", desc: "Calcule a soma de todos os números de 1 até 50.", hint: "Crie uma variável soma = 0 antes do loop.", code: "#include <iostream>\nusing namespace std;\n\nint main() {\n    return 0;\n}" },
        { id: 24, title: "Números Pares 1-20", desc: "Imprima todos os números pares entre 1 e 20 usando um loop.", hint: "if(i % 2 == 0)", code: "#include <iostream>\nusing namespace std;\n\nint main() {\n    return 0;\n}" },
        { id: 25, title: "Fatorial de N", desc: "Leia um número e calcule o fatorial dele (ex: 5! = 120).", hint: "Use um loop multiplicando os valores.", code: "#include <iostream>\nusing namespace std;\n\nint main() {\n    return 0;\n}" },
        { id: 26, title: "Contagem Regressiva", desc: "Faça um loop que conte de 10 até 0.", hint: "for(int i=10; i>=0; i--)", code: "#include <iostream>\nusing namespace std;\n\nint main() {\n    return 0;\n}" },
        { id: 27, title: "Média de N Números", desc: "Leia 5 números em um loop e ao final mostre a média deles.", hint: "Some tudo dentro do loop e divida por 5 no fim.", code: "#include <iostream>\nusing namespace std;\n\nint main() {\n    return 0;\n}" },
        { id: 28, title: "Potência Quadrada", desc: "Imprima o quadrado dos números de 1 a 5.", hint: "cout << i * i;", code: "#include <iostream>\nusing namespace std;\n\nint main() {\n    return 0;\n}" },
        { id: 29, title: "Busca de Número", desc: "Leia 5 números. Se algum deles for 0, imprima 'Zero encontrado'.", hint: "Use if dentro do for.", code: "#include <iostream>\nusing namespace std;\n\nint main() {\n    return 0;\n}" },
        { id: 30, title: "CALCULADORA COMPLETA", desc: "Leia n1, o operador (+, -, *, /) e n2. Use switch para mostrar o resultado.", hint: "switch(operador) { case '+': ... }", code: "#include <iostream>\nusing namespace std;\n\nint main() {\n    float n1, n2;\n    char op;\n    cout << \"Digite: Num1 Operador Num2\\n\";\n    // Resolva o desafio final!\n    return 0;\n}" }
    ];

    const sidebar = document.getElementById('sidebar');
    const editor = document.getElementById('code-editor');
    const consoleBox = document.getElementById('console');
    let currentId = 1;

    // Gerar lista na barra lateral
    questions.forEach(q => {
        const item = document.createElement('div');
        item.className = 'q-item';
        item.id = `nav-${q.id}`;
        item.innerHTML = `<b>${q.id}.</b> ${q.title}`;
        item.onclick = () => loadQuestion(q.id);
        sidebar.appendChild(item);
    });

    function loadQuestion(id) {
        currentId = id;
        const q = questions.find(x => x.id === id);
        document.getElementById('title').innerText = q.title;
        document.getElementById('desc').innerText = q.desc;
        document.getElementById('hint').innerText = q.hint;
        document.getElementById('stat').innerText = `Questão ${id} de 30`;
        
        const saved = localStorage.getItem(`cpp_pro_${id}`);
        editor.value = saved || q.code;

        document.querySelectorAll('.q-item').forEach(el => el.classList.remove('q-active'));
        document.getElementById(`nav-${id}`).classList.add('q-active');
        consoleBox.innerText = "Aguardando execução...";
    }

    function runCpp() {
        consoleBox.innerHTML = "Compilando main.cpp...\nExecutando terminal...\n----------------------\n";
        const code = editor.value;
        localStorage.setItem(`cpp_pro_${currentId}`, code);

        // Simulador de Output
        const outputs = code.match(/"([^"]+)"/g);
        
        // Simulador de Input
        if(code.includes("cin >>")) {
            const userInput = prompt("Terminal C++ (cin): Digite os dados solicitados pelo código.");
            if(userInput) consoleBox.innerHTML += ">> cin: " + userInput + "\n";
        }

        if(outputs) {
            outputs.forEach(m => {
                consoleBox.innerHTML += m.replace(/"/g, "") + "\n";
            });
        } else {
            consoleBox.innerHTML += "[Sucesso] Código compilado. Verifique se você usou cout corretamente.";
        }
    }

    loadQuestion(1);
</script>
</body>
</html>
