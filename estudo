<!DOCTYPE html>
<html lang="pt-br">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>C++ Academy - 30 Desafios</title>

<style>
:root { --primary: #659ad2; --accent: #00ff95; --bg: #0d1117; --surface: #161b22; --border: #30363d; --text: #c9d1d9; }
body { font-family: 'Segoe UI', sans-serif; background: var(--bg); color: var(--text); margin: 0; display: flex; flex-direction: column; height: 100vh; overflow: hidden; }
header { background: var(--surface); padding: 10px 20px; border-bottom: 1px solid var(--border); display: flex; justify-content: space-between; align-items: center; }
.logo { color: var(--primary); font-weight: 800; font-size: 1.2rem; }
main { display: grid; grid-template-columns: 300px 1fr; flex: 1; overflow: hidden; }
#sidebar { background: var(--surface); border-right: 1px solid var(--border); overflow-y: auto; padding: 15px; }
.q-item { padding: 10px; margin-bottom: 6px; border-radius: 6px; cursor: pointer; font-size: 13px; transition: 0.2s; border: 1px solid transparent; background: #21262d44; }
.q-item:hover { background: #21262d; }
.q-active { background: #23863633; border-color: #238636; color: var(--accent); }
#editor-container { display: grid; grid-template-rows: auto 1fr 160px; overflow: hidden; }
#instructions { background: #0d1117; padding: 15px 25px; border-bottom: 1px solid var(--border); }
.toolbar { background: #161b22; padding: 8px 20px; display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid var(--border); }
textarea { background: #0d1117; color: #79c0ff; padding: 20px; border: none; font-family: 'Consolas', monospace; font-size: 15px; outline: none; resize: none; }
#console { background: #000; color: #00ff00; padding: 15px; font-family: monospace; font-size: 13px; overflow-y: auto; border-top: 1px solid var(--border); white-space: pre-wrap; }
.btn-run { background: #238636; color: white; border: none; padding: 8px 20px; border-radius: 6px; font-weight: bold; cursor: pointer; }
</style>
</head>

<body>

<header>
<div class="logo">C++ ACADEMY_</div>
<div id="stat">Questão 1/30</div>
</header>

<main>
<nav id="sidebar"></nav>

<section id="editor-container">
<div id="instructions">
<h2 id="title" style="margin:0; color:var(--primary); font-size: 1.2rem;">Carregando...</h2>
<p id="desc" style="margin: 5px 0 0 0; font-size: 0.9rem; color: #8b949e;"></p>
</div>

<div style="display:flex; flex-direction:column; overflow:hidden;">
<div class="toolbar">
<span>main.cpp</span>
<button class="btn-run" onclick="executeCpp()">COMPILAR & RODAR</button>
</div>
<textarea id="code-editor" spellcheck="false"></textarea>
</div>

<div id="console">O console aguarda seu código...</div>
</section>
</main>

<script>
// (mesmo array questions que você já tinha — mantido)
const questions = [ /* SEU ARRAY CONTINUA IGUAL — NÃO MUDE NADA */ ];
</script>

<script>
// ===== LÓGICA =====
const sidebar = document.getElementById('sidebar');
const editor = document.getElementById('code-editor');
const consoleBox = document.getElementById('console');
let currentId = 1;

questions.forEach(q => {
const item = document.createElement('div');
item.className = 'q-item';
item.id = `item-${q.id}`;
item.innerHTML = `<b>${q.id}.</b> ${q.title}`;
item.onclick = () => load(q.id);
sidebar.appendChild(item);
});

function load(id) {
currentId = id;
const q = questions.find(x => x.id === id);
document.getElementById('title').innerText = q.title;
document.getElementById('desc').innerText = q.desc;
document.getElementById('stat').innerText = `Questão ${id}/30`;

const saved = localStorage.getItem(`cpp_study_${id}`);
editor.value = saved || q.code;

document.querySelectorAll('.q-item').forEach(el => el.classList.remove('q-active'));
document.getElementById(`item-${id}`).classList.add('q-active');
}

// ===== NOVO "COMPILADOR" =====
function executeCpp() {
consoleBox.innerHTML = "Compilando C++... [OK]\nExecutando...\n----------------------\n";
const code = editor.value;
localStorage.setItem(`cpp_study_${currentId}`, code);

let jsCode = code;

// Limpeza
jsCode = jsCode.replace(/#include.*\n/g, '');
jsCode = jsCode.replace(/using namespace std;/g, '');
jsCode = jsCode.replace(/int main\(\)\s*{/, '');
jsCode = jsCode.replace(/return 0;/g, '');
jsCode = jsCode.replace(/}/g, '');

// Tipos
jsCode = jsCode.replace(/\bint\b/g, 'let');
jsCode = jsCode.replace(/\bfloat\b/g, 'let');
jsCode = jsCode.replace(/\bstring\b/g, 'let');
jsCode = jsCode.replace(/\bchar\b/g, 'let');

// cin
jsCode = jsCode.replace(/cin\s*>>\s*(\w+)/g, '$1 = Number(prompt("Entrada:"))');

// cout
jsCode = jsCode.replace(/cout\s*<<\s*/g, 'print(');
jsCode = jsCode.replace(/;\s*$/gm, ');');

// endl
jsCode = jsCode.replace(/<<\s*endl/g, '');

function print(msg) {
consoleBox.innerHTML += msg + "\n";
}

try {
eval(jsCode);
} catch (e) {
consoleBox.innerHTML += "\n[ERRO] " + e.message;
}
}

load(1);
</script>

</body>
</html>
