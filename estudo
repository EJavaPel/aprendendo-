<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>DevMaster - 30 Desafios Reais</title>
    <style>
        :root { --primary: #00e676; --bg: #121212; --surface: #1e1e1e; --text: #ffffff; --accent: #ffd600; }
        body { font-family: 'Segoe UI', sans-serif; background: var(--bg); color: var(--text); margin: 0; display: flex; flex-direction: column; height: 100vh; overflow: hidden; }
        header { background: var(--surface); padding: 15px; display: flex; justify-content: space-between; align-items: center; border-bottom: 3px solid var(--primary); }
        main { display: flex; flex: 1; overflow: hidden; }
        #sidebar { width: 260px; background: #181818; border-right: 1px solid #333; overflow-y: auto; padding: 10px; }
        .q-item { padding: 10px; margin-bottom: 5px; background: #252525; cursor: pointer; border-radius: 4px; font-size: 13px; transition: 0.2s; }
        .q-item:hover { background: #333; }
        .q-active { border-left: 4px solid var(--primary); background: #333; font-weight: bold; }
        #content { flex: 1; display: flex; flex-direction: column; padding: 20px; gap: 15px; overflow-y: auto; }
        #description-card { background: var(--surface); padding: 20px; border-radius: 8px; border-left: 5px solid var(--primary); }
        #workspace { flex: 1; display: flex; flex-direction: column; background: #1e1e1e; border-radius: 8px; border: 1px solid #333; overflow: hidden; min-height: 400px; }
        .toolbar { background: #2d2d2d; padding: 10px; display: flex; justify-content: space-between; }
        textarea { flex: 1; background: #1e1e1e; color: #a6e22e; padding: 15px; border: none; font-family: 'Consolas', monospace; font-size: 15px; outline: none; resize: none; }
        #console-output { height: 120px; background: #000; color: #00ff00; padding: 10px; font-family: monospace; border-top: 2px solid #333; overflow-y: auto; white-space: pre-wrap; }
        .btn-run { background: var(--primary); border: none; padding: 8px 20px; font-weight: bold; cursor: pointer; border-radius: 4px; }
        .btn-hint { background: none; border: 1px solid var(--accent); color: var(--accent); padding: 5px; cursor: pointer; font-size: 11px; margin-top: 10px; border-radius: 3px; }
        #hint-text { display: none; color: var(--accent); margin-top: 10px; font-size: 13px; font-style: italic; }
    </style>
</head>
<body>

<header>
    <div style="color:var(--primary); font-weight:bold;">SOLO_DEV v2.0</div>
    <div id="progress">Questão 1 de 30</div>
</header>

<main>
    <nav id="sidebar"></nav>
    <section id="content">
        <div id="description-card">
            <h2 id="q-title" style="margin:0">Carregando...</h2>
            <p id="q-text"></p>
            <button class="btn-hint" onclick="document.getElementById('hint-text').style.display='block'">💡 Precisa de ajuda?</button>
            <div id="hint-text"></div>
        </div>
        <div id="workspace">
            <div class="toolbar"><span>Editor JavaScript</span><button class="btn-run" onclick="runCode()">EXECUTAR RUN</button></div>
            <textarea id="editor" spellcheck="false"></textarea>
            <div id="console-output"></div>
        </div>
    </section>
</main>

