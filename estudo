<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>DevMaster - 100 Desafios de Programação</title>
    <style>
        :root {
            --primary: #00e676;
            --bg: #121212;
            --surface: #1e1e1e;
            --text: #ffffff;
            --accent: #ffd600;
            --danger: #ff5252;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: var(--bg);
            color: var(--text);
            margin: 0;
            display: flex;
            flex-direction: column;
            height: 100vh;
            overflow: hidden;
        }

        /* Header */
        header {
            background: var(--surface);
            padding: 15px 25px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 3px solid var(--primary);
            box-shadow: 0 4px 10px rgba(0,0,0,0.3);
        }

        .logo { font-weight: bold; font-size: 1.2rem; color: var(--primary); }
        .progress-text { font-size: 0.9rem; background: #333; padding: 5px 12px; border-radius: 20px; }

        /* Layout Principal */
        main {
            display: flex;
            flex: 1;
            overflow: hidden;
        }

        /* Barra Lateral */
        #sidebar {
            width: 280px;
            background: #181818;
            border-right: 1px solid #333;
            overflow-y: auto;
            padding: 15px;
        }

        .q-item {
            padding: 12px;
            margin-bottom: 8px;
            background: #252525;
            cursor: pointer;
            border-radius: 6px;
            font-size: 14px;
            transition: all 0.2s;
            border-left: 4px solid transparent;
        }

        .q-item:hover { background: #333; transform: translateX(5px); }
        .q-active { border-left-color: var(--primary); background: #333; font-weight: bold; }

        /* Conteúdo Central */
        #content {
            flex: 1;
            display: flex;
            flex-direction: column;
            padding: 20px;
            gap: 15px;
            overflow-y: auto;
        }

        #description-card {
            background: var(--surface);
            padding: 20px;
            border-radius: 10px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.2);
        }

        #q-title { margin-top: 0; color: var(--primary); }
        
        /* Sistema de Dicas */
        .btn-hint {
            background: none;
            border: 1px solid var(--accent);
            color: var(--accent);
            padding: 6px 12px;
            border-radius: 4px;
            cursor: pointer;
            margin-top: 10px;
            font-size: 0.8rem;
        }

        #hint-box {
            display: none;
            margin-top: 10px;
            padding: 10px;
            background: #332b00;
            border-radius: 4px;
            font-size: 0.9rem;
            color: var(--accent);
            border-left: 3px solid var(--accent);
        }

        /* Editor e Console */
        #workspace {
            flex: 1;
            display: flex;
            flex-direction: column;
            background: #1e1e1e;
            border-radius: 10px;
            overflow: hidden;
            border: 1px solid #333;
        }

        .toolbar {
            background: #2d2d2d;
            padding: 10px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        textarea {
            flex: 1;
            background: #1e1e1e;
            color: #a6e22e;
            padding: 20px;
            border: none;
            font-family: 'Consolas', 'Monaco', monospace;
            font-size: 16px;
            outline: none;
            resize: none;
            line-height: 1.5;
        }

        #console-output {
            height: 140px;
            background: #000;
            color: #00ff00;
            padding: 15px;
            font-family: 'Courier New', monospace;
            font-size: 14px;
            border-top: 2px solid #333;
            overflow-y: auto;
            white-space: pre-wrap;
        }

        .btn-run {
            background: var(--primary);
            color: #000;
            border: none;
            padding: 10px 25px;
            font-weight: bold;
            border-radius: 5px;
            cursor: pointer;
            transition: 0.3s;
        }

        .btn-run:hover { background: #00c864; transform: scale(1.05); }
        
        .btn-clear {
            background: var(--danger);
            color: white;
            border: none;
            padding: 5px 10px;
            border-radius: 4px;
            cursor: pointer;
            font-size: 0.7rem;
        }
    </style>
</head>
<body>

<header>
    <div class="logo">CODE_MASTER // 100 Desafios</div>
    <div>
        <span id="progress-label" class="progress-text">Carregando...</span>
        <button class="btn-clear" onclick="resetAll()" style="margin-left: 10px;">Resetar Tudo</button>
    </div>
</header>

<main>
    <nav id="sidebar"></nav>

    <section id="content">
        <div id="description-card">
            <h2 id="q-title">Iniciando...</h2>
            <p id="q-text">Selecione um desafio na lista lateral para começar sua jornada.</p>
            <button class="btn-hint" onclick="document.getElementById('hint-box').style.display='block'">💡 Ver Dica</button>
            <div id="hint-box"></div>
        </div>

        <div id="workspace">
            <div class="toolbar">
                <span>Editor de Código (JavaScript / Lógica)</span>
                <button class="btn-run" onclick="runCode()">EXECUTAR</button>
            </div>
            <textarea id="editor" spellcheck="false"></textarea>
            <div id="console-output">O resultado do seu código aparecerá aqui...</div>
        </div>
    </section>
</main>

<script>
    const questions = [];
    
    // Gerador de 100 Questões
    for (let i = 1; i <= 100; i++) {
        let title, text, hint, startCode;

        if (i <= 20) {
            title = `Fundamentos ${i}: Variáveis`;
            text = i === 1 ? "Exiba 'Olá, Mundo!' usando o comando print()." : `Nível ${i}: Peça um dado usando input() e exiba-o com print().`;
            hint = "Use print('texto') para saída e let x = input('pergunta') para entrada.";
            startCode = i === 1 ? "print('Olá, Mundo!');" : "// Digite seu código aqui";
        } else if (i <= 50) {
            title = `Lógica ${i}: Condicionais`;
            text = `Crie um programa que use 'if' para verificar se um número é maior que ${i}.`;
            hint = "if (valor > " + i + ") { print('Maior'); }";
            startCode = "let num = input('Digite um número:');\nif(Number(num) > "+i+") {\n  print('É maior!');\n}";
        } else if (i <= 80) {
            title = `Loop ${i}: Repetições`;
            text = `Use um loop 'for' para imprimir números de 1 até ${Math.floor(i/2)}.`;
            hint = "for(let i=1; i<=limite; i++) { print(i); }";
            startCode = "for(let i=1; i <= 5; i++) {\n  print('Contagem: ' + i);\n}";
        } else {
            title = i === 100 ? "DESAFIO FINAL: Calculadora" : `Projeto ${i}: Funções`;
            text = i === 100 ? "Crie uma calculadora completa: peça 2 números e uma operação (+, -, *, /) e mostre o resultado." : "Crie uma função que retorne o dobro de um número.";
            hint = "Use if/else ou switch para identificar a operação na calculadora.";
            startCode = "// Rumo ao nível 100!";
        }

        questions.push({ id: i, title, text, hint, code: startCode });
    }

    const sidebar = document.getElementById('sidebar');
    const editor = document.getElementById('editor');
    const consoleOut = document.getElementById('console-output');
    const hintBox = document.getElementById('hint-box');
    let currentQId = 1;

    // Popular Sidebar
    questions.forEach(q => {
        const div = document.createElement('div');
        div.className = 'q-item';
        div.id = `qitem-${q.id}`;
        div.innerHTML = `<strong>${q.id}.</strong> ${q.title.split(':')[0]}`;
        div.onclick = () => loadQuestion(q.id);
        sidebar.appendChild(div);
    });

    function loadQuestion(id) {
        currentQId = id;
        const q = questions.find(item => item.id === id);
        
        document.getElementById('q-title').innerText = q.title;
        document.getElementById('q-text').innerText = q.text;
        document.getElementById('progress-label').innerText = `Questão ${id} de 100`;
        
        const savedCode = localStorage.getItem(`devcode_${id}`);
        editor.value = savedCode ? savedCode : q.code;
        
        hintBox.innerText = q.hint;
        hintBox.style.display = 'none';

        document.querySelectorAll('.q-item').forEach(el => el.classList.remove('q-active'));
        document.getElementById(`qitem-${id}`).classList.add('q-active');
    }

    function runCode() {
        consoleOut.innerText = "";
        const code = editor.value;
        
        // Salvar progresso
        localStorage.setItem(`devcode_${currentQId}`, code);

        const print = (val) => { consoleOut.innerText += "> " + val + "\n"; };
        const input = (msg) => { return prompt(msg); };

        try {
            eval(code);
            consoleOut.innerText += "\n[Sucesso: Código executado]";
        } catch (err) {
            consoleOut.innerText += "\n[Erro]: " + err.message;
        }
    }

    function resetAll() {
        if(confirm("Deseja apagar todo o seu progresso salvo?")) {
            localStorage.clear();
            location.reload();
        }
    }

    // Iniciar na questão 1
    loadQuestion(1);
</script>

</body>
</html>
