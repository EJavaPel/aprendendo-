        { id: 76, modulo: 'MAT', title: "Média de Coluna", desc: "Média dos valores da segunda coluna.", code: "" },
        { id: 77, modulo: 'MAT', title: "Transposição", desc: "Gere a matriz transposta de uma matriz dada.", code: "" },
        { id: 78, modulo: 'MAT', title: "Contador de Zeros", desc: "Conte os zeros em uma matriz 4x4.", code: "" },
        { id: 79, modulo: 'MAT', title: "Batalha Naval", desc: "Ache o caractere 'S' escondido na matriz 5x5.", code: "" },
        { id: 80, modulo: 'MST', title: "SISTEMA DE CINEMA", desc: "DESAFIO FINAL: Gerencie uma sala 5x5. Crie um mapa de assentos (0 vago, 1 ocupado) com sistema de reserva.", code: "" }
    ];

    const sidebar = document.getElementById('sidebar');
    const editor = document.getElementById('editor');
    const consoleBox = document.getElementById('console');
    let currentId = 1;

    function toggleTheory(show) {
        document.getElementById('theory-modal').style.display = show ? 'flex' : 'none';
    }

    function load(id) {
        currentId = id;
        const q = questions.find(x => x.id === id);
        document.getElementById('q-title').innerText = `${String(q.id).padStart(2, '0')} // ${q.title}`;
        document.getElementById('q-desc').innerText = q.desc;
        editor.value = localStorage.getItem(`cpp_final_v9_q${id}`) || q.code || "#include <iostream>\nusing namespace std;\n\nint main() {\n    // Codifique seu algoritmo aqui\n    \n    return 0;\n}";
        document.querySelectorAll('.q-item').forEach(el => el.classList.remove('q-active'));
        document.getElementById(`item-${id}`).classList.add('q-active');
        consoleBox.innerText = "Pronto para codificar a questão " + id + "...";
    }

    function salvar() {
        localStorage.setItem(`cpp_final_v9_q${currentId}`, editor.value);
        consoleBox.innerHTML = `<div><span style="color:var(--accent)">[SYSTEM]</span> Questão ${currentId} compilada com sucesso e salva em cache.</div>`;
        updateProg();
    }

    function updateProg() {
        let count = 0;
        questions.forEach(q => { if(localStorage.getItem(`cpp_final_v9_q${q.id}`)) count++; });
        let percent = Math.round((count/80)*100);
        document.getElementById('prog-txt').innerText = `${percent}%`;
        document.getElementById('prog-fill').style.width = `${percent}%`;
    }

    function init() {
        questions.sort((a,b) => a.id - b.id).forEach(q => {
            const div = document.createElement('div');
            div.className = 'q-item';
            div.id = `item-${q.id}`;
            div.innerHTML = `<span>MOD_${q.modulo}</span><b>${String(q.id).padStart(2, '0')}. ${q.title}</b>`;
            div.onclick = () => load(q.id);
            sidebar.appendChild(div);
        });
        load(1);
        updateProg();
    }

    window.addEventListener('keydown', (e) => { if(e.key === "Escape") toggleTheory(false); });
    window.onload = init;
</script>
</body>
</html>
