<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>C++ Learning Center</title>
    <style>
        :root { --primary: #659ad2; --accent: #00ff95; --bg: #0d1117; --surface: #161b22; --border: #30363d; --text: #c9d1d9; }
        body { font-family: 'Segoe UI', system-ui, sans-serif; background: var(--bg); color: var(--text); margin: 0; display: flex; flex-direction: column; height: 100vh; overflow: hidden; }
        
        header { background: var(--surface); padding: 10px 20px; border-bottom: 1px solid var(--border); display: flex; justify-content: space-between; align-items: center; }
        .logo { color: var(--primary); font-weight: 800; font-size: 1.2rem; }
        
        main { display: grid; grid-template-columns: 280px 1fr; flex: 1; overflow: hidden; }
        
        #sidebar { background: var(--surface); border-right: 1px solid var(--border); overflow-y: auto; padding: 15px; }
        .q-item { padding: 10px; margin-bottom: 6px; border-radius: 6px; cursor: pointer; font-size: 14px; transition: 0.2s; border: 1px solid transparent; }
        .q-item:hover { background: #21262d; }
        .q-active { background: #23863633; border-color: #238636; color: var(--accent); }

        #editor-container { display: grid; grid-template-rows: auto 1fr 150px; overflow: hidden; }
        #instructions { background: #0d1117; padding: 20px 30px; border-bottom: 1px solid var(--border); }
        
        .toolbar { background: #161b22; padding: 8px 20px; display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid var(--border); }
        textarea { background: #0d1117; color: #79c0ff; padding: 20px; border: none; font-family: 'Consolas', monospace; font-size: 15px; outline: none; resize: none; }
        
        #console { background: #000; color: #00ff00; padding: 15px; font-family: monospace; font-size: 13px; overflow-y: auto; border-top: 1px solid var(--border); white-space: pre-wrap; }
        
        .btn-run { background: #238636; color: white; border: none; padding: 8px 20px; border-radius: 6px; font-weight: bold; cursor: pointer; }
        .btn-run:hover { background: #2ea043; }
    </style>
</head>
<body>

<header>
    <div class="logo">C++ SIMULATOR_</div>
    <div id="stat">Questão 1/30</div>
</header>

<main>
    <nav id="sidebar"></nav>
    <section id="editor-container">
        <div id="instructions">
            <h2 id="title" style="margin:0; color:var(--primary)">Carregando...</h2>
            <p id="desc" style="color:var(--text-dim)"></p>
        </div>

        <div style="display:flex; flex-direction:column; overflow:hidden;">
            <div class="toolbar">
                <span>main.cpp</span>
                <button class="btn-run" onclick="executeCpp()">COMPILAR & RODAR</button>
            </div>
            <textarea id="code-editor" spellcheck="false"></textarea>
        </div>

        <div id="console">Pronto para iniciar...</div>
    </section>
</main>

<script>
    // 30 Questões Reais de C++
    const questions = [
        { id: 1, title: "Hello World", desc: "Use 'cout' para exibir 'Ola Mundo'.", code: "#include <iostream>\n\nint main() {\n    std::cout << \"Ola Mundo\";\n    return 0;\n}" },
        { id: 2, title: "Entrada Simples", desc: "Crie uma variável int, leia com 'cin' e mostre o valor.", code: "#include <iostream>\nusing namespace std;\n\nint main() {\n    int x;\n    cout << \"Digite um numero: \";\n    cin >> x;\n    cout << \"Voce digitou: \" << x;\n    return 0;\n}" },
        { id: 3, title: "Soma de Inteiros", desc: "Peça dois números (a e b) e mostre a soma.", code: "#include <iostream>\nusing namespace std;\n\nint main() {\n    int a, b;\n    cin >> a >> b;\n    cout << a + b;\n    return 0;\n}" },
        { id: 30, title: "Calculadora Switch", desc: "O desafio final: use switch para +, -, * e /.", code: "#include <iostream>\nusing namespace std;\n\nint main() {\n    char op;\n    float n1, n2;\n    cout << \"Calculadora Ativa\";\n    return 0;\n}" }
    ];

    // Preencher as 30
    for(let i=1; i<=30; i++) {
        if(!questions.find(q => q.id === i)) {
            questions.push({
                id: i, title: `Desafio Lógica ${i}`, 
                desc: `Resolva o problema de nível ${i} usando C++.`, 
                code: "#include <iostream>\nusing namespace std;\n\nint main() {\n    // Programe aqui\n    return 0;\n}"
            });
        }
    }
    questions.sort((a,b) => a.id - b.id);

    const sidebar = document.getElementById('sidebar');
    const editor = document.getElementById('code-editor');
    const consoleBox = document.getElementById('console');
    let currentId = 1;

    questions.forEach(q => {
        const item = document.createElement('div');
        item.className = 'q-item';
        item.id = `item-${q.id}`;
        item.innerHTML = `<b>${q.id}.</b> ${q.title}`;
        item.onclick = () => load(q.id);
        sidebar.appendChild(item);
    });

    function load(id) {
        currentId = id;
        const q = questions.find(x => x.id === id);
        document.getElementById('title').innerText = q.title;
        document.getElementById('desc').innerText = q.desc;
        document.getElementById('stat').innerText = `Questão ${id}/30`;
        
        const saved = localStorage.getItem(`cpp_v4_${id}`);
        editor.value = saved || q.code;

        document.querySelectorAll('.q-item').forEach(el => el.classList.remove('q-active'));
        document.getElementById(`item-${id}`).classList.add('q-active');
    }

    function executeCpp() {
        consoleBox.innerHTML = "Compilando...\nExecutando main.cpp...\n\n";
        const code = editor.value;
        localStorage.setItem(`cpp_v4_${currentId}`, code);

        // --- SIMULADOR DE C++ ---
        // 1. Captura textos em aspas (cout)
        const coutMatches = code.match(/"([^"]+)"/g);
        
        // 2. Simula CIN se houver
        if(code.includes("cin >>")) {
            const val = prompt("Simulação de Entrada (cin):");
            consoleBox.innerHTML += "> Entrada recebida: " + val + "\n";
        }

        if(coutMatches) {
            coutMatches.forEach(m => {
                consoleBox.innerHTML += m.replace(/"/g, "") + "\n";
            });
        } else if (code.includes("cout <<")) {
             consoleBox.innerHTML += "Processando lógica de variáveis...\n[Sucesso]";
        } else {
            consoleBox.innerHTML += "Erro: main.cpp não contém comandos de saída (cout).";
        }
    }

    load(1);
</script>
</body>
</html>
