        .theory-card h2 { color: var(--accent); font-size: 1.4rem; margin-top: 40px; display: flex; align-items: center; gap: 10px; }
        .theory-card h2::before { content: '>'; color: var(--primary); }
        .theory-card p { color: var(--text-dim); font-size: 1.05rem; margin: 15px 0; }
        .theory-card ul { padding-left: 20px; margin: 20px 0; }
        .theory-card li { color: var(--text-dim); margin-bottom: 12px; }
        .theory-card strong { color: var(--text-main); }
        .theory-card code { background: var(--code-bg); color: #79c0ff; padding: 3px 8px; border-radius: 5px; font-family: 'Consolas', monospace; font-size: 0.95rem; border: 1px solid var(--border); }
        
        .close-theory { position: sticky; top: 0; float: right; background: #ff4d4d; color: white; border: none; padding: 10px 20px; border-radius: 8px; cursor: pointer; font-weight: bold; z-index: 600; box-shadow: 0 4px 15px rgba(255,77,77,0.3); }

